{
  "template_name": "电影感混剪",
  "version": "1.0",
  "description": "宽屏黑边+电影色调+缓慢转场，适合影视混剪、氛围感短片",
  "author": "北辰",
  "category": "创意/艺术",
  "defaults": {
    "width": 1920,
    "height": 1080,
    "fps": 24,
    "bitrate": "8M",
    "clip_duration": 4,
    "transition": "fadeblack",
    "transition_duration": 1.0,
    "filter": "dramatic"
  },
  "overlays": [
    {
      "type": "text",
      "position": "bottom-center",
      "content": "— {subtitle} —",
      "font_size": 24,
      "font_color": "white",
      "animation": "fade-in",
      "start": 0,
      "duration": 3
    }
  ],
  "audio": {
    "bgm_style": "cinematic-orchestral",
    "volume": {"bgm": 0.4, "original": 0.5},
    "fade": {"in": 2.0, "out": 3.0}
  }
}
