{
  "template_name": "轮播展示",
  "version": "1.0",
  "description": "每个产品/图片停留5秒，带名称和价格标签，适合多商品展示",
  "author": "北辰",
  "category": "带货/营销",
  "defaults": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "bitrate": "4M",
    "clip_duration": 5,
    "transition": "fade",
    "transition_duration": 0.4
  },
  "overlays": [
    {
      "type": "text",
      "position": "bottom-center",
      "content": "{product_name}",
      "font_size": 36,
      "font_color": "white",
      "bg_color": "black@0.5",
      "animation": "fade-in",
      "start": 0.5,
      "duration": 3
    },
    {
      "type": "text",
      "position": "bottom-center",
      "content": "¥{price}",
      "font_size": 32,
      "font_color": "yellow",
      "animation": "fade-in",
      "start": 2,
      "duration": 2.5
    },
    {
      "type": "watermark",
      "image": "",
      "position": "top-right",
      "scale": 0.1
    }
  ],
  "audio": {
    "bgm_style": "lo-fi",
    "volume": {"bgm": 0.2, "original": 1.0},
    "fade": {"in": 1.0, "out": 1.0}
  }
}
