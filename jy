def cmd_template(args):
    """模板化剪辑"""
    engine = TemplateEngine()
    video_dir = Path(args.video_dir)

    videos = sorted([str(p) for p in video_dir.glob("*.mp4")] +
                    [str(p) for p in video_dir.glob("*.mov")] +
                    [str(p) for p in video_dir.glob("*.avi")] +
                    [str(p) for p in video_dir.glob("*.mkv")])

    if not videos:
        print(f"❌ 目录中没有视频文件: {args.video_dir}")
        sys.exit(1)

    output = args.output or f"{args.template_name}.mp4"

    print(f"📋 模板: {args.template_name}")
    print(f"   视频数: {len(videos)}")
    print(f"   输出: {output}")

    result = engine.render_template(args.template_name, videos, output)
    if result.get("success"):
        print(f"✅ 模板剪辑完成!")
    else:
        print(f"❌ 失败: {result.get('error', '未知错误')}")
        sys.exit(1)


