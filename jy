def cmd_info(args):
    """查看视频信息"""
    info = get_video_info(args.video)
    print(f"文件:     {info['path']}")
    print(f"分辨率:   {info['width']}x{info['height']}")
    print(f"帧率:     {info['fps']} fps")
    print(f"时长:     {info['duration']:.2f} 秒")
    print(f"编码:     {info['codec']}")
    print(f"像素格式: {info['pix_fmt']}")
    print(f"码率:     {info['bitrate']} bps")


def cmd_concat(args):
    """拼接视频"""
    if len(args.videos) < 2:
        print("❌ 至少需要2个视频文件")
        sys.exit(1)

    output = args.output or "output.mp4"
    transition = args.transition or "fade"
    duration = args.duration or 0.3

    print(f"📦 拼接 {len(args.videos)} 个视频...")
    print(f"   转场: {transition} ({duration}s)")
    print(f"   输出: {output}")

    result = stitch(
        args.videos, output,
        transition=transition,
        transition_duration=duration,
    )

    if result["success"]:
        info = result["info"]
        print(f"✅ 拼接完成!")
        print(f"   时长: {info['duration']}s")
        print(f"   分辨率: {info['resolution']}")
        print(f"   输出: {result['output']}")
    else:
        print(f"❌ 失败: {result['error']}")
        sys.exit(1)


def cmd_trim(args):
    """裁剪视频片段"""
    from utils.ffmpeg import run_ffmpeg

    output = args.output or f"{Path(args.video).stem}_trim.mp4"

    cmd = ["ffmpeg", "-y", "-i", args.video]
    if args.start:
        cmd += ["-ss", args.start]
    if args.end:
        cmd += ["-to", args.end]
    if args.duration:
        cmd += ["-t", str(args.duration)]
    cmd += ["-c:v", "libx264", "-c:a", "aac", output]

    print(f"✂️  裁剪: {args.video}")
    if args.start: print(f"   开始: {args.start}")
    if args.end: print(f"   结束: {args.end}")
    print(f"   输出: {output}")

    result = run_ffmpeg(cmd)
    if result["success"]:
        print(f"✅ 裁剪完成!")
    else:
        print(f"❌ 失败: {result.get('stderr', '未知错误')[:500]}")
        sys.exit(1)


