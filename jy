def cmd_speed(args):
    """变速"""
    from utils.ffmpeg import run_ffmpeg

    output = args.output or f"{Path(args.video).stem}_x{args.speed}.mp4"

    print(f"⚡ 变速: x{args.speed}")
    print(f"   输入: {args.video}")
    print(f"   输出: {output}")

    setpts = 1.0 / args.speed
    atempo = args.speed

    # atempo 范围 0.5~2.0，超出需要链式调用
    if atempo < 0.5:
        atempo = 0.5
    elif atempo > 100.0:
        atempo = 100.0

    # 处理 atempo 超出 [0.5, 2.0] 的情况
    def build_atempo(target):
        chains = []
        while target > 2.0:
            chains.append("atempo=2.0")
            target /= 2.0
        while target < 0.5:
            chains.append("atempo=0.5")
            target /= 0.5
        chains.append(f"atempo={target:.3f}")
        return ",".join(chains)

    audio_filter = build_atempo(atempo)

    cmd = [
        "ffmpeg", "-y", "-i", args.video,
        "-filter:v", f"setpts={setpts}*PTS",
        "-filter:a", audio_filter,
        "-c:v", "libx264", "-c:a", "aac", output,
    ]

    result = run_ffmpeg(cmd)
    if result["success"]:
        print(f"✅ 变速完成!")
    else:
        print(f"❌ 失败: {result.get('stderr', '')[:500]}")
        sys.exit(1)


def cmd_crop(args):
    """裁剪尺寸"""
    from utils.ffmpeg import run_ffmpeg

    output = args.output or f"{Path(args.video).stem}_crop.mp4"
    res = args.resolution or "1080x1920"

    print(f"✂️  裁剪尺寸: {res}")
    print(f"   输入: {args.video}")
    print(f"   输出: {output}")

    w, h = res.split("x")
    cmd = [
        "ffmpeg", "-y", "-i", args.video,
        "-vf", f"scale={w}:{h}:force_original_aspect_ratio=decrease,pad={w}:{h}:(ow-iw)/2:(oh-ih)/2",
        "-c:v", "libx264", "-c:a", "aac", output,
    ]

    result = run_ffmpeg(cmd)
    if result["success"]:
        print(f"✅ 裁剪完成!")
    else:
        print(f"❌ 失败: {result.get('stderr', '')[:500]}")
        sys.exit(1)


