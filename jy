#!/usr/bin/env python3
"""
JY — 命令行视频剪辑工具

用法:
  jy info <视频>                 查看视频信息
  jy concat <视频1> <视频2> ...  拼接视频（自动分析参数+转场）
  jy trim <视频> -s 00:01:00 -e 00:02:30 -o <输出>   裁剪
  jy filter <视频> -f vintage -o <输出>   应用滤镜
  jy subtitle <视频> -s <字幕.srt> -o <输出>  烧录字幕
  jy text <视频> -t "文字" -o <输出>     叠加文字
  jy audio <视频> -b <bgm.mp3> -o <输出>  添加背景音乐
  jy speed <视频> -x 2.0 -o <输出>  变速
  jy crop <视频> -r 1080x1920 -o <输出>  裁剪尺寸
  jy volume <视频> -o <输出>      音量标准化
  jy extract-audio <视频> -o <输出.mp3> 提取音频
  jy remove-silence <视频> -o <输出>  去除静音
  jy template <模板名> <视频目录> -o <输出>  模板化剪辑
  jy batch <配置文件.json>        批量处理
  jy list-templates               列出可用预设模板
  jy list-filters                 列出可用滤镜
  jy list-transitions             列出可用转场

示例:
  jy concat clip1.mp4 clip2.mp4 clip3.mp4 -o 成片.mp4
  jy concat clip1.mp4 clip2.mp4 -t slideleft -d 0.5 -o out.mp4
  jy trim input.mp4 -s 00:01:30 -e 00:03:00 -o clip.mp4
  jy filter input.mp4 -f dramatic -o output.mp4
  jy text input.mp4 -t "Hello World" -p center -o output.mp4
  jy audio input.mp4 -b bgm.mp3 --ducking -o output.mp4
  jy speed input.mp4 -x 2.0 -o fast.mp4
"""

import sys
import os
