        print()


def cmd_batch(args):
    """批量处理"""
    config_path = Path(args.config)
    if not config_path.exists():
        print(f"❌ 配置文件不存在: {args.config}")
        sys.exit(1)

    with open(config_path) as f:
        config = json.load(f)

    print(f"📦 批量处理 ({len(config.get('tasks', []))} 个任务)")
    results = []

    for i, task in enumerate(config.get("tasks", []), 1):
        task_type = task.get("type", "concat")
        print(f"\n  [{i}/{len(config['tasks'])}] {task_type}: {task.get('output', '?')}")

        try:
            if task_type == "concat":
                r = stitch(task["videos"], task["output"],
                           transition=task.get("transition", "fade"),
                           transition_duration=task.get("duration", 0.3))
            elif task_type == "filter":
                r = apply_builtin_filter(task["video"], task["filter"], task["output"])
            elif task_type == "audio":
                r = add_bgm(task["video"], task["bgm"], task["output"],
                            bgm_volume=task.get("bgm_volume", 0.3),
                            ducking=task.get("ducking", False))
            else:
                r = {"success": False, "error": f"未知任务类型: {task_type}"}

            status = "✅" if r["success"] else "❌"
            print(f"  {status} {r.get('output', task['output'])}")
            results.append(r)
        except Exception as e:
            print(f"  ❌ 异常: {e}")
            results.append({"success": False, "error": str(e)})

    success_count = sum(1 for r in results if r.get("success"))
    print(f"\n📊 完成: {success_count}/{len(config['tasks'])}")


def main():
    parser = argparse.ArgumentParser(
        description="JY — 命令行视频剪辑工具",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  jy info video.mp4
  jy concat clip1.mp4 clip2.mp4 clip3.mp4 -o final.mp4
  jy concat clip1.mp4 clip2.mp4 -t slideleft -d 0.5 -o out.mp4
  jy trim input.mp4 -s 00:01:30 -e 00:03:00 -o clip.mp4
  jy filter input.mp4 -f dramatic -o output.mp4
  jy text input.mp4 -t "Hello World" -p top-center -o output.mp4
  jy audio input.mp4 -b bgm.mp3 --ducking -o output.mp4
  jy speed input.mp4 -x 2.0 -o fast.mp4
        """
    )
    subparsers = parser.add_subparsers(dest="command", help="子命令")

    # info
    p = subparsers.add_parser("info", help="查看视频信息")
    p.add_argument("video", help="视频文件路径")

    # concat
    p = subparsers.add_parser("concat", help="拼接视频")
    p.add_argument("videos", nargs="+", help="视频文件列表")
    p.add_argument("-o", "--output", help="输出文件")
    p.add_argument("-t", "--transition", default="fade", help="转场类型 (默认: fade)")
    p.add_argument("-d", "--duration", type=float, default=0.3, help="转场时长秒 (默认: 0.3)")

    # trim
    p = subparsers.add_parser("trim", help="裁剪视频片段")
    p.add_argument("video", help="视频文件路径")
    p.add_argument("-s", "--start", help="开始时间 (00:01:30)")
    p.add_argument("-e", "--end", help="结束时间 (00:03:00)")
    p.add_argument("-t", "--duration", type=float, help="时长（秒）")
    p.add_argument("-o", "--output", help="输出文件")

    # filter
    p = subparsers.add_parser("filter", help="应用滤镜")
    p.add_argument("video", help="视频文件路径")
    p.add_argument("-f", "--filter-name", required=True, help="滤镜名称")
    p.add_argument("-o", "--output", help="输出文件")

    p = subparsers.add_parser("list-filters", help="列出可用滤镜")
    p = subparsers.add_parser("list-transitions", help="列出可用转场")

    # subtitle / text
    p = subparsers.add_parser("text", help="叠加文字")
    p.add_argument("video", help="视频文件路径")
    p.add_argument("-t", "--text", help="文字内容")
    p.add_argument("-s", "--srt", help="SRT字幕文件")
    p.add_argument("-p", "--position", default="bottom-center", help="位置 (默认: bottom-center)")
    p.add_argument("--font-size", type=int, default=36, help="字号 (默认: 36)")
    p.add_argument("-o", "--output", help="输出文件")

    # audio
    p = subparsers.add_parser("audio", help="添加背景音乐")
    p.add_argument("video", help="视频文件路径")
    p.add_argument("-b", "--bgm", help="BGM文件路径")
    p.add_argument("--bgm-volume", type=float, default=0.3, help="BGM音量 (默认: 0.3)")
    p.add_argument("--original-volume", type=float, default=1.0, help="原声音量 (默认: 1.0)")
    p.add_argument("--ducking", action="store_true", help="开启人声优先")
    p.add_argument("-o", "--output", help="输出文件")

    # speed
    p = subparsers.add_parser("speed", help="变速")
    p.add_argument("video", help="视频文件路径")
    p.add_argument("-x", "--speed", type=float, required=True, help="速度倍率 (0.5~2.0)")
    p.add_argument("-o", "--output", help="输出文件")

    # crop
    p = subparsers.add_parser("crop", help="裁剪尺寸")
    p.add_argument("video", help="视频文件路径")
    p.add_argument("-r", "--resolution", help="分辨率 (如 1080x1920)")
    p.add_argument("-o", "--output", help="输出文件")

    # volume
    p = subparsers.add_parser("volume", help="音量标准化")
    p.add_argument("video", help="视频文件路径")
    p.add_argument("-o", "--output", help="输出文件")

    # extract-audio
    p = subparsers.add_parser("extract-audio", help="提取音频")
    p.add_argument("video", help="视频文件路径")
    p.add_argument("-o", "--output", help="输出文件 (.mp3 或 .m4a)")

    # remove-silence
    p = subparsers.add_parser("remove-silence", help="去除静音")
    p.add_argument("video", help="视频文件路径")
    p.add_argument("-o", "--output", help="输出文件")

    # template
    p = subparsers.add_parser("template", help="模板化剪辑")
    p.add_argument("template_name", help="模板名称")
    p.add_argument("video_dir", help="视频目录路径")
    p.add_argument("-o", "--output", help="输出文件")

    p = subparsers.add_parser("list-templates", help="列出可用模板")

    # batch
    p = subparsers.add_parser("batch", help="批量处理")
    p.add_argument("config", help="配置文件 (.json)")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    commands = {
        "info": cmd_info,
        "concat": cmd_concat,
        "trim": cmd_trim,
        "filter": cmd_filter,
        "list-filters": cmd_list_filters,
        "list-transitions": cmd_list_transitions,
        "text": cmd_subtitle,
        "audio": cmd_audio,
        "speed": cmd_speed,
        "crop": cmd_crop,
        "volume": cmd_volume,
        "extract-audio": cmd_extract_audio,
        "remove-silence": cmd_remove_silence,
        "template": cmd_template,
        "list-templates": cmd_list_templates,
        "batch": cmd_batch,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
